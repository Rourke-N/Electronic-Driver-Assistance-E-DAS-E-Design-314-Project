	const char *reset_cmd = "$PUBX,41,1,0007,0003,9600,0*10\r\n";
	HAL_UART_Transmit(&huart6, (uint8_t*) reset_cmd, strlen(reset_cmd), 1000);
	HAL_Delay(500); /* give the module time to reset and re-init at 9600 */
}

